{
  "name": "cryptogram",
  "version": "2.0.0",
  "description": "Cryptogram puzzle solution helper",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:netlify": "vite build --outDir netlify && vite build --outDir netlify/cryptogram",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ./src ./e2e playwright.config.js",
    "lint:fix": "eslint ./src ./e2e playwright.config.js --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/craigmcn/cryptogram.git"
  },
  "keywords": [
    "cryptogram",
    "puzzle",
    "help",
    "scratchpad"
  ],
  "author": "Craig McNaughton",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "axe-core": "^4.12.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "neostandard": "^0.13.0",
    "prettier": "^3.8.3",
    "sass": "^1.77.6",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.14.1",
  "resolutions": {
    "@babel/core": "^7.29.6",
    "ejs": "^5.0.1",
    "js-yaml": "^4.2.0",
    "node-gyp": "^12.2.0",
    "semver": "^7.5.2",
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.20",
    "vite": "^6.4.3"
  }
}
